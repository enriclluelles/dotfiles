export PATH="$HOME/.bin:$PATH"
export PATH="/usr/local/bin:/usr/local/sbin:/usr/local/mysql/bin:/usr/local/git/bin:$PATH"
# Use homebrew's python
export PATH="/usr/local/opt/python/libexec/bin:$PATH"
export PATH="$HOME/bin:$PATH"
# go
export PATH="${GOPATH//://bin:}/bin:$PATH"
# rust
export PATH="$HOME/.rustup/toolchains/stable-x86_64-unknown-linux-gnu/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"
#One addition per line, easier to remove
export PATH="/opt/local/bin:$PATH"
export PATH="./node_modules/.bin:$PATH"
export PATH="/usr/local/heroku/bin:$PATH"
#If coreutils are installed, use them
export PATH="/usr/local/opt/coreutils/libexec/gnubin:$PATH"
export PATH="/opt/go/latest/bin:$PATH"
export MANPATH="/usr/local/man:/usr/local/mysql/man:/usr/local/git/man:$MANPATH"
